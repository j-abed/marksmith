{
  "name": "marksmith",
  "version": "0.2.0",
  "description": "Local-first Markdown editor where Markdown is the canonical source of truth",
  "license": "MIT",
  "type": "module",
  "author": "Jason Abed (https://github.com/j-abed)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/j-abed/marksmith.git"
  },
  "bugs": {
    "url": "https://github.com/j-abed/marksmith/issues"
  },
  "homepage": "https://j-abed.github.io/marksmith/app/",
  "keywords": [
    "markdown",
    "editor",
    "codemirror",
    "local-first",
    "pwa",
    "react"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "start": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:pages": "PAGES_BUILD=1 sh -c 'tsc -b && vite build'",
    "capture:showcase": "npm run build:pages && node scripts/capture-showcase.mjs",
    "lint": "oxlint",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "npm test && npm run test:e2e"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.3",
    "@lezer/highlight": "^1.2.3",
    "highlight.js": "^11.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-highlight": "^7.0.2",
    "rehype-parse": "^9.0.1",
    "rehype-react": "^8.0.0",
    "rehype-remark": "^10.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/hast": "^3.0.4",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
